<aside class="sidebar">
  <h4 class="sidebar-heading">Posts Recentes</h4>
  <ul class="sidebar-posts">
    {% set allPosts = collections.posts | reverse %}
    {% for post in allPosts %}
    <li class="sidebar-post{% if page.url == post.url %} sidebar-post--active{% endif %}">
      <a href="{{ post.url }}">{{ post.data.title }}</a>
      <span class="sidebar-date">{{ post.date | dateFormat }}</span>
    </li>
    {% endfor %}
  </ul>
</aside>
