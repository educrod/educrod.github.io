---
layout: base.njk
---

<article class="post">
  <h1>{{ title }}</h1>

  {% if translationKey %}
    {% set translations = collections.postsByTranslationKey[translationKey] %}
    <div class="lang-switcher">
      {% if lang == 'pt' and translations.en %}
        <a href="{{ translations.en.url }}">🇺🇸 Read in English</a>
      {% endif %}
      {% if lang == 'en' and translations.pt %}
        <a href="{{ translations.pt.url }}">🇧🇷 Ler em Português</a>
      {% endif %}
    </div>
  {% endif %}

  <div class="entry">
    {{ content | safe }}
  </div>

  <div class="date">
    {{ page.date | dateFormat }}
  </div>
  {% include "disqus.njk" %}
</article>
<script>
  const copyText = 'Copy';

  document
    .querySelector('.post')
    .querySelectorAll('pre.highlight')
    .forEach(function (pre) {
      const code = pre.querySelector('code');
      if (!code) return;

      const button = document.createElement('button');
      button.className = 'copy';
      button.type = 'button';
      button.setAttribute('aria-label', 'Copy code to clipboard');
      button.innerText = copyText;

      button.addEventListener('click', function () {
        button.classList.add('copy--clicked');
        navigator.clipboard.writeText(code.innerText.trim()).then(function () {
          button.innerText = 'Done';
          setTimeout(function () {
            button.innerText = copyText;
            button.classList.remove('copy--clicked');
          }, 4000);
        }).catch(function () {
          button.innerText = 'Error';
          setTimeout(function () {
            button.innerText = copyText;
            button.classList.remove('copy--clicked');
          }, 4000);
        });
      });

      pre.appendChild(button);
    });
</script>
