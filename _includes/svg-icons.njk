{% set links = metadata["footer-links"] %}

{% if links.dribbble %}
<a href="https://www.dribbble.com/{{ links.dribbble }}"><i class="svg-icon dribbble"></i></a>
{% endif %}

{% if links.email %}
<a href="mailto:{{ links.email }}"><i class="svg-icon email"></i></a>
{% endif %}

{% if links.facebook %}
<a href="https://www.facebook.com/{{ links.facebook }}"><i class="svg-icon facebook"></i></a>
{% endif %}

{% if links.flickr %}
<a href="https://www.flickr.com/photos/{{ links.flickr }}"><i class="svg-icon flickr"></i></a>
{% endif %}

{% if links.github %}
<a href="https://github.com/{{ links.github }}"><i class="svg-icon github"></i></a>
{% endif %}

{% if links.instagram %}
<a href="https://instagram.com/{{ links.instagram }}"><i class="svg-icon instagram"></i></a>
{% endif %}

{% if links.linkedin %}
<a href="https://www.linkedin.com/in/{{ links.linkedin }}"><i class="svg-icon linkedin"></i></a>
{% endif %}

{% if links.pinterest %}
<a href="https://pinterest.com/{{ links.pinterest }}"><i class="svg-icon pinterest"></i></a>
{% endif %}

{% if links.rss %}
<a href="{{ metadata.baseurl }}/feed.xml"><i class="svg-icon rss"></i></a>
{% endif %}

{% if links.stackoverflow %}
<a href="https://www.stackoverflow.com/users/{{ links.stackoverflow }}"><i class="svg-icon stackoverflow"></i></a>
{% endif %}

{% if links.twitter %}
<a href="https://twitter.com/{{ links.twitter }}"><i class="svg-icon twitter"></i></a>
{% endif %}

{% if links.youtube %}
<a href="https://www.youtube.com/{{ links.youtube }}"><i class="svg-icon youtube"></i></a>
{% endif %}

{% if links.googleplus %}
<a href="https://plus.google.com/{{ links.googleplus }}"><i class="svg-icon googleplus"></i></a>
{% endif %}
