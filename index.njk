---
layout: base.njk
---

<div class="lang-filter">
  <button class="lang-btn active" data-lang="all">All</button>
  <button class="lang-btn" data-lang="pt">🇧🇷 PT</button>
  <button class="lang-btn" data-lang="en">🇺🇸 EN</button>
</div>

<div class="posts">
  {% for post in collections.posts | reverse %}
    <article class="post" data-lang="{{ post.data.lang }}">

      <h1><a href="{{ post.url }}">{{ post.data.title }}</a></h1>

      <div class="post-meta">
        {{ post.date | dateFormat }}
        {% if post.data.lang %}
          <span class="lang-badge">{{ post.data.lang | upper }}</span>
        {% endif %}
      </div>

      <div class="entry">
        {{ post.templateContent | excerpt | safe }}
      </div>

      <a href="{{ post.url }}" class="read-more">Read More</a>
    </article>
  {% endfor %}
</div>

<script>
  const buttons = document.querySelectorAll('.lang-btn');
  const posts = document.querySelectorAll('.posts .post');

  buttons.forEach(function (btn) {
    btn.addEventListener('click', function () {
      const lang = btn.dataset.lang;

      buttons.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');

      posts.forEach(function (post) {
        if (lang === 'all' || post.dataset.lang === lang) {
          post.style.display = '';
        } else {
          post.style.display = 'none';
        }
      });
    });
  });
</script>
